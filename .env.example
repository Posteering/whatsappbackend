# Backend Environment Variables
# Copy this file to .env and fill in the values

# ──────────────────────────────────────────────────────────────
# Database (PostgreSQL) — Required
# Get from Railway: your PostgreSQL service → Connect tab
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname

# ──────────────────────────────────────────────────────────────
# Redis — Required (used for user-mode state tracking)
# Get from Railway: your Redis service → Connect tab
# ──────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:port

# ──────────────────────────────────────────────────────────────
# WhatsApp Cloud API — Required
# Get from: Meta Developer Dashboard → WhatsApp → API Setup
# ──────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=choose_any_secret_string
WHATSAPP_API_TOKEN=your_meta_access_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# ──────────────────────────────────────────────────────────────
# Anthropic Claude AI — Required
# Get from: https://console.anthropic.com/settings/keys
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ──────────────────────────────────────────────────────────────
# Posteering One API (BankRail) — Required for payments
# Get from: https://app.posteering.com (sandbox credentials)
# ──────────────────────────────────────────────────────────────
POSTEERING_API_KEY=oak_...
POSTEERING_KEY_ID=your_key_id
POSTEERING_API_SECRET=your_api_secret
POSTEERING_CONTEXT_ID=ctx_...

# ──────────────────────────────────────────────────────────────
# Escrow Ledger — Required for payment disbursements
# Create a ledger account in the Posteering dashboard and paste
# the account ID here.
# ──────────────────────────────────────────────────────────────
ESCROW_LEDGER_ACCOUNT_ID=

# ──────────────────────────────────────────────────────────────
# Admin Dashboard API Key — Required
# Set any strong secret string. Include it as the
# "x-admin-key" header when calling /api/v1/admin/* routes.
# ──────────────────────────────────────────────────────────────
ADMIN_API_KEY=choose_a_strong_secret

# ──────────────────────────────────────────────────────────────
# Internal Security
# ──────────────────────────────────────────────────────────────
SECRET_KEY=choose_a_long_random_string
